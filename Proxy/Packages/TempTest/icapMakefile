
INC = /usr/include/libxml2

PROJECT_BINARY_NAME = IcapTest
PROJECT_SOURCES = IcapTest.c

INCLUDES += -I$(INC)

all:	$(PROJECT_BINARY_NAME)

CFLAGS  += -Wall -O
CFLAGS  += -DDEBUG -D_WEATHERXX

LDLIBS  += -lsqlite3 -lcurl -lxml2

$(PROJECT_BINARY_NAME): $(PROJECT_SOURCES)
	$(CC) $(CFLAGS) $(LDFLAGS) -o $(PROJECT_BINARY_NAME) $(PROJECT_SOURCES) $(INCLUDES) $(LDLIBS)

clean:
	rm -f $(PROJECT_BINARY_NAME)
